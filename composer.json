{
    "name": "alifaleh302-dev/clothing-store",
    "description": "نظام متجر ملابس إلكتروني متكامل - PHP MVC (محاسبة + CRM)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:${PORT:-8080} -t public public/index.php",
        "migrate": "php database/migrate.php"
    },
    "config": {
        "platform": {
            "php": "8.1"
        }
    }
}
